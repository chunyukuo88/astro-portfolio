---
import Cube from './Cube.jsx';
import { skills } from "../content/skills";
const baseDelay = 120;
---

<main aria-labelledby="my-skills">
    <div class="column-shell">
        <h3 id="my-skills">
            <span aria-hidden="true">My Skills</span>
        </h3>

        <section aria-labelledby="frontend-skills">
            <h4 class="skill-type"><span>Front End</span></h4>

            <div class="display-skills-wrapper">
                <ul class="display-skills">
                    {skills.frontEndSkills.map((skill, i) => (
                        <li class="skill" style={`animation-delay: ${(i + 1) * 4 * baseDelay}ms`}>
                            {skill}
                        </li>
                    ))}
                </ul>
            </div>
        </section>
        <section aria-labelledby="backend-skills">
            <h4 class="skill-type"><span>Back End</span></h4>

            <div class="display-skills-wrapper">
                <ul class="display-skills">
                    {skills.backEndSkills.map((skill, i) => (
                        <li class="skill" style={`animation-delay: ${(i + 1) * 4 * baseDelay}ms`}>
                            {skill}
                        </li>
                    ))}
                </ul>
            </div>
        </section>
        <section aria-labelledby="aws-skills">
            <h4 class="skill-type"><span>AWS</span></h4>

            <div class="display-skills-wrapper">
                <ul class="display-skills">
                    {skills.awsSkills.map((skill, i) => (
                        <li class="skill" style={`animation-delay: ${(i + 1) * 4 * baseDelay}ms`}>
                            {skill}
                        </li>
                    ))}
                </ul>
            </div>
        </section>
        <section aria-labelledby="saas-skills">
            <h4 class="skill-type"><span>CI/CD and the like</span></h4>

            <div class="display-skills-wrapper">
                <ul class="display-skills">
                    {skills.cicdSkills.map((skill, i) => (
                        <li class="skill" style={`animation-delay: ${(i + 1) * 4 * baseDelay}ms`}>
                            {skill}
                        </li>
                    ))}
                </ul>
            </div>
        </section>
        <section aria-labelledby="tooling">
            <h4 class="skill-type"><span>Tooling</span></h4>

            <div class="display-skills-wrapper">
                <ul class="display-skills">
                    {skills.tooling.map((skill, i) => (
                        <li class="skill" style={`animation-delay: ${(i + 1) * 4 * baseDelay}ms`}>
                            {skill}
                        </li>
                    ))}
                </ul>
            </div>
        </section>
        <section aria-labelledby="other">
            <h4 class="skill-type"><span>Other</span></h4>

            <div class="display-skills-wrapper">
                <ul class="display-skills">
                    {skills.other.map((skill, i) => (
                        <li class="skill" style={`animation-delay: ${(i + 1) * 4 * baseDelay}ms`}>
                            {skill}
                        </li>
                    ))}
                </ul>
            </div>
        </section>
        <br>
    </div>
    <Cube client:load />
</main>

<style>
    main {
        width: 50%;
        box-sizing: border-box;
        height: 100%;
    }

    .column-shell {
        border-left: var(--common-line);
        border-right: var(--common-line);
    }

    :global(.dark) .column-shell {
        border-left: var(--common-line-dark);
        border-right: var(--common-line-dark);
    }

    section {
        margin-bottom: 2rem;
    }

    #my-skills, .skill-type {
        margin-top: 0;
        padding-left: 2rem;
        border-bottom: var(--common-line);
    }

    :global(.dark) #my-skills, :global(.dark) .skill-type {
        border-bottom: var(--common-line-dark);
    }

    #my-skills > span, .skill-type > span {
        margin-left: 0.5rem;
    }

    .skill {
        --fadeColor: var('black');
        opacity: 0;
        color: black;
        animation: fade-in 8s ease forwards;
        list-style: none;
        margin: 0;
    }

    @keyframes fade-in {
        to {
            opacity: 1;
            color: var(--fadeColor);
        }
    }

    @media (max-width: 640px) {
        main {
            width: 90%;
            height: fit-content(100%);
        }

        .display-skills {
            margin-left: 2px;
        }
    }
</style>