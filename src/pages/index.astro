---
import BaseLayout from '../layouts/BaseLayout.astro'

const frontEndSkills = [
    'CSS preprocessors',
    'SVG & animations',
    'White-labelling',
    'Web components',
    'React + Vite',
    'Storybook',
    'Tailwind',
    'Next.js',
    'Svelte',
    'Astro',
    'SCSS',
    'msw',
    'UX',
    '*',
];
const baseDelay = 120;
---

<BaseLayout>
    <main>
        <h3 id="my-skills"><span>:: My Skills ::</span></h3>

        <h4 class="skill-type"><span>Front End</span></h4>

        <div id="display-skills">
            {frontEndSkills.map((skill, i) => (
                <div class="skill" style={`animation-delay: ${(i + 1) * 2 * baseDelay}ms`}>
                    {skill}
                </div>
            ))}
        </div>
    </main>
</BaseLayout>


<style>
    main {
        //display: grid;
        //grid-template-rows: 4rem 4rem 1fr;

        width: 50%;
        height: 100%;
        border-left: var(--common-line);
        border-right: var(--common-line);
    }

    #my-skills, .skill-type {
        padding-left: 0.5rem;
        border-bottom: var(--common-line);
    }

    #my-skills > span, .skill-type > span {
        margin-left: 0.5rem;
    }

    #display-skills {
        margin-left: 1rem;

        .skill {
            opacity: 0;
            animation: fade-in 10s ease forwards;
            color: var(--primaryColor);
            list-style: none;
        }
    }

    @keyframes fade-in {
        to {
            opacity: 1;
        }
    }

    @media (max-width: 640px) {
        main {
            width: 100%;
        }

        h3, h4 {
            inset: 0;
            margin-left: 0.5rem;
            margin-right: 0.5rem;
        }
    }
</style>