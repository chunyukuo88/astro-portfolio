---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout>
    <h3 id="projects">
        <span aria-hidden="true">Projects</span>
    </h3>
    <div class="card-wrapper">
        <div class="card">hello</div>
        <div class="card">hello</div>
        <div class="card">hello</div>
        <div class="card">hello</div>
        <div class="card">hello</div>
    </div>
</BaseLayout>




<style>
    #projects {
        margin-top: 0;
        border-bottom: var(--common-line);
        padding-left: 2rem;
    }
    .card-wrapper {
        width: 50%;
    }
    .card {
        width: 100%;
        height: 300px;
        background: green;
        margin-bottom: 3rem;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .card:nth-child(1) {
        clip-path: polygon(0% 0%, 100% 0%, 100% 80%, 100% 100%, 20% 100%, 20% 80%, 0% 80%);
    }

    .card:nth-child(2) {
        clip-path: polygon(0% 0%, 20% 0%, 20% 20%, 100% 20%, 100% 100%, 80% 100%, 80% 80%, 60% 80%, 40% 80%, 40% 100%, 0% 100%);
        background: red;
    }

    .card:nth-child(3) {
        clip-path: polygon(0% 20%, 40% 20%, 40% 0%, 80% 0%, 80% 20%, 100% 20%, 100% 80%, 80% 80%, 80% 100%, 40% 100%, 40% 80%, 0% 80%);
        background: green;
    }

    .card:nth-child(4) {
        background: red;
        clip-path: polygon(0% 0%, 40% 0%, 40% 20%, 80% 20%, 80% 0%, 100% 0%, 100% 100%, 80% 100%, 80% 80%, 60% 80%, 60% 100%, 40% 100%, 40% 80%, 20% 80%, 20% 100%, 0% 100%);
    }

    .card:nth-child(5) {
        background: green;
        clip-path: polygon(0% 20%, 20% 20%, 20% 0%, 40% 0%, 40% 20%, 60% 20%, 60% 0%, 80% 0%, 80% 20%, 100% 20%, 100% 100%, 0% 100%);
    }
</style>